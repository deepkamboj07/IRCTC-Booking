generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  PASSENGER
  ADMIN
}

enum TrainType {
  EXPRESS
  SUPERFAST
  LOCAL
}

enum SeatClassName {
  SLEEPER
  AC_3TIER
  AC_2TIER
  AC_FIRST_CLASS
}

enum BerthType {
  LOWER
  MIDDLE
  UPPER
  SIDE_LOWER
  SIDE_UPPER
}

enum ScheduleStatus {
  SCHEDULED
  RUNNING
  ARRIVED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
}

enum PassengerGender {
  MALE
  FEMALE
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  role         Role      @default(PASSENGER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bookings Booking[]
}

model Station {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  city      String
  state     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routeStops           TrainRouteStop[]
  fromSeatAvailability SeatAvailability[] @relation("SeatAvailabilityFrom")
  toSeatAvailability   SeatAvailability[] @relation("SeatAvailabilityTo")
  fromBookings         Booking[]          @relation("BookingFrom")
  toBookings           Booking[]          @relation("BookingTo")
}

model Train {
  id          String    @id @default(cuid())
  trainNumber String    @unique
  name        String
  type        TrainType
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  routeStops TrainRouteStop[]
  coaches    Coach[]
  schedules  TrainSchedule[]
}

model TrainRouteStop {
  id            String  @id @default(cuid())
  trainId       String
  stationId     String
  sequence      Int
  arrivalTime   String?
  departureTime String?
  distanceKm    Int

  train   Train   @relation(fields: [trainId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id])

  @@unique([trainId, sequence])
  @@unique([trainId, stationId])
}

model SeatClass {
  id              String        @id @default(cuid())
  name            SeatClassName @unique
  displayName     String
  priceMultiplier Decimal       @db.Decimal(4, 2)

  coaches Coach[]
}

model Coach {
  id          String @id @default(cuid())
  trainId     String
  coachNumber String
  seatClassId String
  totalSeats  Int

  train            Train              @relation(fields: [trainId], references: [id], onDelete: Cascade)
  seatClass        SeatClass          @relation(fields: [seatClassId], references: [id])
  seats            Seat[]
  seatAvailability SeatAvailability[]

  @@unique([trainId, coachNumber])
}

model Seat {
  id         String    @id @default(cuid())
  coachId    String
  seatNumber Int
  berthType  BerthType

  coach             Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  bookingPassengers BookingPassenger[]

  @@unique([coachId, seatNumber])
}

model TrainSchedule {
  id          String         @id @default(cuid())
  trainId     String
  journeyDate DateTime       @db.Date
  status      ScheduleStatus @default(SCHEDULED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  train            Train              @relation(fields: [trainId], references: [id], onDelete: Cascade)
  seatAvailability SeatAvailability[]
  bookings         Booking[]

  @@unique([trainId, journeyDate])
}

model SeatAvailability {
  id             String @id @default(cuid())
  scheduleId     String
  coachId        String
  fromStationId  String
  toStationId    String
  availableCount Int

  schedule    TrainSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  coach       Coach         @relation(fields: [coachId], references: [id])
  fromStation Station       @relation("SeatAvailabilityFrom", fields: [fromStationId], references: [id])
  toStation   Station       @relation("SeatAvailabilityTo", fields: [toStationId], references: [id])

  @@unique([scheduleId, coachId, fromStationId, toStationId])
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  scheduleId    String
  fromStationId String
  toStationId   String
  pnr           String        @unique
  status        BookingStatus @default(PENDING)
  totalFare     Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        User               @relation(fields: [userId], references: [id])
  schedule    TrainSchedule      @relation(fields: [scheduleId], references: [id])
  fromStation Station            @relation("BookingFrom", fields: [fromStationId], references: [id])
  toStation   Station            @relation("BookingTo", fields: [toStationId], references: [id])
  passengers  BookingPassenger[]
}

model BookingPassenger {
  id        String          @id @default(cuid())
  bookingId String
  seatId    String
  name      String
  age       Int
  gender    PassengerGender
  status    BookingStatus   @default(CONFIRMED)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat    Seat    @relation(fields: [seatId], references: [id])

  @@unique([seatId, bookingId])
}
